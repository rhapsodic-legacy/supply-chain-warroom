# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database (Docker Compose provides these defaults)
DATABASE_URL=postgresql+asyncpg://supply_room:localdev@localhost:5432/supply_room

# SQLite fallback (uncomment to use instead of PostgreSQL)
# DATABASE_URL=sqlite+aiosqlite:///./supply_chain_warroom.db

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
