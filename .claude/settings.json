{
  "permissions": {
    "allow": [
      "Bash(python3 -m pytest:*)",
      "Bash(python3 -m uvicorn:*)",
      "Bash(python3 -m app.*)",
      "Bash(npm test:*)",
      "Bash(npm run:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prettier:*)",
      "Bash(ruff:*)",
      "Bash(git:*)",
      "Bash(curl localhost:*)",
      "Bash(docker-compose:*)",
      "Bash(docker compose:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Agent"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-save-format.sh \"$FILE_PATH\""
          }
        ]
      }
    ]
  }
}
